# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs.txt

# env files — never commit secrets (use .env.example as the template)
.env
.env.local
.env.development
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated files (produced by `npx prisma generate`)
/src/generated/prisma

# database
/prisma/dev.db
/prisma/dev.db-journal

# editor / tooling
.playwright-mcp/
.claude/
.idea/
.vscode/
