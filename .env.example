# =============================================================================
# Environment variables — copy this file to ".env" and fill in real values.
# NEVER commit your real .env file. This template is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic Claude API key (OPTIONAL)
# -----------------------------------------------------------------------------
# Used by src/lib/provider.ts to generate React components with Claude.
# If left empty, the app falls back to a built-in MOCK provider that returns
# static components — so the app runs end-to-end without any key.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# JWT signing secret (REQUIRED in production)
# -----------------------------------------------------------------------------
# Used by src/lib/auth.ts to sign/verify session tokens (jose, HS256).
# In development it falls back to an insecure default; in production you MUST
# set a long, random value. Generate one with:  openssl rand -base64 32
JWT_SECRET=

# -----------------------------------------------------------------------------
# Database connection URL (Prisma)
# -----------------------------------------------------------------------------
# The Prisma schema (prisma/schema.prisma) uses SQLite by default via
# "file:./dev.db" and does not require this variable locally. It is provided
# here for deployments that override the datasource (e.g. Postgres):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# Node environment
# -----------------------------------------------------------------------------
# Set automatically by most hosts. Controls secure-cookie behavior in auth.ts
# and the Prisma client singleton in prisma.ts. Usually "development" or
# "production".
# NODE_ENV=development
